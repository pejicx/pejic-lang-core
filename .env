AGENT_AUTO_APPROVE=true
AGENT_DEFAULT_GROUP:workers
AGENT_REGISTRATION_TOKEN: "Master"
AGENT_STORAGE_BUCKE=my-agents-buckers
ALLOW_CUSTOM_SCRIPTS=true
API_KEY_EXPIRATION_DAYS=365
AUTO_BOOST=true
AUTO_GENERATE_API_KEY=true
BOOT=true
BOOTABLE=true
BUILDER_ENV=production
CONTAINER_RUNTIME=kubernetes
DEBUG=api:automation:*
ENCRYPTED=false
ENABLE_AGENT_NETWORK_ACCESS=true
MAX_AGENTS=unlimited
MAX_BATCH_SIZE=100
AGENT_DEFAULT_INSTRUCTION_FILE="Agent.Instruction.md"
COPILOT_DEFAULT_INSTRUCTION_FILE="Copilot.Instruction.md"
