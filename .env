AGENT_AUTO_APPROVE=true
AGENT_DEFAULT_GROUP:workers
AGENT_REGISTRATION_TOKEN: "Master"
AGENT_STORAGE_BUCKE=my-agents-buckers
ALLOW_CUSTOM_SCRIPTS=true
API_KEY_EXPIRATION_DAYS=365
AUTO_BOOST=true
AUTO_GENERATE_API_KEY=true
BOOT=true
BOOTABLE=true
BUILDER_ENV=production
CONTAINER_RUNTIME=kubernetes
DEBUG=api:automation:*
ENCRYPTED=false
ENABLE_AGENT_NETWORK_ACCESS=true
MAX_AGENTS=unlimited
MAX_BATCH_SIZE=100
AGENT_DEFAULT_INSTRUCTION_FILE="Agent.Instruction.md"
COPILOT_DEFAULT_INSTRUCTION_FILE="Copilot.Instruction.md"

# Agent Identity
AGENT_NAME="Approve-Bot-01"
AGENT_INSTRUCTIONS_PATH="./instructions/auto_approve.md"

# Auto-Approve Thresholds
MAX_AUTO_APPROVE_AMOUNT=1000  # Automatski odobri do 1000$ (npr. refund ili budžet)
REQUIRED_CONFIDENCE_SCORE=0.95 # Agent mora biti 95% siguran u odluku
AUTO_REJECT_BLACKLISTED_EMAILS=true

# Identity
AGENT_NAME="worker-node-01"
AGENT_DEFAULT_GROUP="workers"
AGENT_VERSION="1.0.0"

# Filesystem Paths
AGENT_INSTRUCTIONS_PATH="./instructions/worker_agent.md"
AGENT_WORK_DIR="./temp/tasks"

# Connection & Security
MASTER_API_URL="https://api.yourdomain.com/v1"
AGENT_AUTH_TOKEN="your-secure-shared-key"

# Operational Limits
MAX_CONCURRENT_TASKS=3
HEARTBEAT_INTERVAL_SEC=30
