{
  "ai_tuning": {
    "creativity_index": 0.88,
    "logic_safety_buffer": "maximum",
    "llm_priorities": {
      "primary": "structural_clarity",
      "secondary": "performance_optimization",
      "tertiary": "idiomatic_refinement"
    },
    "behavior_mode": "impactful-writing-safe-logic"
  }.
  {
  "enchantment_rules": {
    "coding": {
      "paradigm_preference": "functional",
      "patterns": ["immutability", "pure_functions", "higher_order_functions"],
      "avoid": ["global_state", "heavy_loops", "mutations"]
    },
    "writing": {
      "output_flavor": "sensory_vivid",
      "imagery_level": "high",
      "prose_enhancement": ["texture", "atmosphere", "rhythm"],
      "anti_dry_filter": true
    }
  },
  {
  "connectivity": {
    "cloud": {
      "endpoint": "https://api.pejicx.ai/v2/enchant",
      "protocol": "wss",
      "timeout_ms": 3500,
      "heartbeat_interval": 15
    },
    "reliability": {
      "retry_strategy": "exponential_backoff",
      "max_retries": 3,
      "fallback_trigger_ms": 4000
    },
    "offline_mode": {
      "enabled_fallback": true,
      "local_engine": "MEC-Lite-GGUF",
      "model_path": "./models/mec_lite_v1.bin",
      "memory_mapping": "lazy",
      "sync_on_reconnect": true
    }
  }
  check_connection() {
    ping -c 1 api.pejicx.ai > /dev/null 2>&1
    if [ $? -eq 0 ]; then
        echo "🌐 MEC Mode: Cloud (Maximum Power)"
        MEC_CURRENT_ENGINE="cloud"
    else
        echo "📶 MEC Mode: Offline Fallback (Lite Engine)"
        MEC_CURRENT_ENGINE="local"
    fi
}
