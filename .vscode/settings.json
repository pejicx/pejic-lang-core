{
    "editor.formatOnSave": true,
    "editor.wordWrap": "on",
    "editor.mouseWheelZoom": true,
    "editor.formatOnPaste": true,
    "editor.accessibilitySupport": "on",
    "editor.autoClosingComments": "never",
    "editor.autoIndent": "full",
    "editor.autoIndentOnPaste": true,
    "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
    "editor.columnSelection": true,
    "editor.definitionLinkOpensInPeek": true,
    "editor.foldingImportsByDefault": true,
    "editor.gotoLocation.alternativeImplementationCommand": "editor.action.referenceSearch.trigger",
    "editor.gotoLocation.multipleDeclarations": "gotoAndPeek",
    "editor.gotoLocation.multipleDefinitions": "gotoAndPeek",
    "editor.gotoLocation.multipleImplementations": "gotoAndPeek",
    "editor.gotoLocation.multipleReferences": "gotoAndPeek",
    "editor.gotoLocation.multipleTypeDefinitions": "gotoAndPeek",
    "editor.guides.bracketPairs": "active",
    "editor.inertialScroll": true,
    "editor.linkedEditing": true,
    "editor.mouseMiddleClickAction": "openLink",
    "editor.renderLineHighlightOnlyWhenFocus": true,
    "editor.renderWhitespace": "all",
    "editor.smoothScrolling": true,
    "editor.stickyTabStops": true,
    "editor.tabCompletion": "on",
    "editor.trimWhitespaceOnDelete": true,
    "editor.unusualLineTerminators": "auto",
    "editor.cursorBlinking": "expand",
    "editor.cursorSmoothCaretAnimation": "explicit",
    "editor.find.autoFindInSelection": "multiline",
    "editor.formatOnType": true,
    "diffEditor.codeLens": true,
    "chat.mcp.discovery.enabled": true
}
